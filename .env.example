# Copy this file to `.env` locally and fill in real values.
# Never commit real secrets.

# Core app
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
DEBUG_LOGS=0
# Local-only operational diagnostics route gate. Leave disabled on public or
# production-like hosts unless you have a short-lived troubleshooting need and
# still keep superuser auth enabled in front of it.
OPERATIONS_DEBUG_ROUTES_ENABLED=0
LOG_LEVEL=info

# Session secret: must be generated per environment and kept private.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Do not reuse this placeholder outside local examples.
SESSION_SECRET=GENERATE_ME_AT_LEAST_32_CHARS_DO_NOT_USE_IN_PRODUCTION
# Optional comma-separated previous session secrets accepted only for verification during a manual rotation window.
# Example: SESSION_SECRET_PREVIOUS=old-secret-1,old-secret-2
SESSION_SECRET_PREVIOUS=
# Dedicated encryption key for stored 2FA secrets. Required before enabling 2FA.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Store this separately from SESSION_SECRET so one secret leak does not compromise both controls.
TWO_FACTOR_ENCRYPTION_KEY=GENERATE_ME_DISTINCT_2FA_KEY_DO_NOT_REUSE_SESSION_SECRET
# Dedicated encryption key for collection PII shadow columns at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Keep this distinct from SESSION_SECRET, 2FA, and backup keys. New/updated collection rows will dual-write encrypted copies when configured.
# Rotation guide: docs/SECRET_ROTATION.md#collection_pii_encryption_key
COLLECTION_PII_ENCRYPTION_KEY=GENERATE_ME_COLLECTION_PII_KEY_DO_NOT_REUSE_SESSION_SECRET
# Optional comma-separated previous collection PII keys accepted only for decryption during a manual rotation window.
# Example: COLLECTION_PII_ENCRYPTION_KEY_PREVIOUS=old-collection-pii-key-1,old-collection-pii-key-2
# During rotation, move only the old key here, keep the new key in COLLECTION_PII_ENCRYPTION_KEY,
# run the staged re-encryption steps from docs/SECRET_ROTATION.md, then clear this value after the compatibility window ends.
COLLECTION_PII_ENCRYPTION_KEY_PREVIOUS=
# Optional staged retirement gate for live reads after plaintext rollout is complete for selected fields.
# Requires COLLECTION_PII_ENCRYPTION_KEY and should only be enabled after the relevant collection:pii-status checks are clean.
# Example staged sensitive retirement: COLLECTION_PII_RETIRED_FIELDS=icNumber,customerPhone,accountNumber
# Example full retirement: COLLECTION_PII_RETIRED_FIELDS=customerName,icNumber,customerPhone,accountNumber
COLLECTION_PII_RETIRED_FIELDS=

# Use an absolute app URL. Example: http://localhost:5000
PUBLIC_APP_URL=http://localhost:5000
# Comma-separated absolute origins only. Do not include paths, query strings, or hashes.
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5173,http://127.0.0.1:5173
# Optional explicit reverse proxies trusted to supply X-Forwarded-For for req.ip / rate limiting.
# Leave empty unless you are behind a known proxy such as Nginx, Caddy, Cloudflare Tunnel, or a load balancer.
# Runtime WebSocket origin checks will only honor X-Forwarded-Host / X-Forwarded-Proto when this list is set.
# Example: TRUSTED_PROXIES=loopback,10.0.0.0/8
TRUSTED_PROXIES=
AUTH_COOKIE_SECURE=auto

# PostgreSQL
# Optional single PostgreSQL URL. If set, it can supply host, port, user,
# password, and database; explicit PG_* values below still override parts when
# provided.
# Current runtime assumes a single primary PostgreSQL connection. Dedicated
# read-replica / reporting connection env vars are not part of the supported
# config surface yet.
# Example: DATABASE_URL=postgres://postgres:strong-password@localhost:5432/sqr_db
DATABASE_URL=
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
# Database password: use a strong password from your secret manager.
# Generate example: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
PG_PASSWORD=GENERATE_ME_DB_PASSWORD_DO_NOT_USE_IN_PRODUCTION
PG_DATABASE=sqr_db
PG_MAX_CONNECTIONS=5
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
PG_SEARCH_PATH=public

# Collection nickname temporary password (auto-generated in dev if empty)
COLLECTION_NICKNAME_TEMP_PASSWORD=

# Receipt security / quarantine
COLLECTION_RECEIPT_QUARANTINE_ENABLED=1
COLLECTION_RECEIPT_QUARANTINE_DIR=var/collection-receipt-quarantine
COLLECTION_RECEIPT_EXTERNAL_SCAN_ENABLED=0
# Example ClamAV command:
# COLLECTION_RECEIPT_EXTERNAL_SCAN_COMMAND=clamscan
# COLLECTION_RECEIPT_EXTERNAL_SCAN_ARGS_JSON=["--no-summary","{file}"]
COLLECTION_RECEIPT_EXTERNAL_SCAN_COMMAND=
COLLECTION_RECEIPT_EXTERNAL_SCAN_ARGS_JSON=["{file}"]
COLLECTION_RECEIPT_EXTERNAL_SCAN_TIMEOUT_MS=15000
COLLECTION_RECEIPT_EXTERNAL_SCAN_FAIL_CLOSED=1
COLLECTION_RECEIPT_EXTERNAL_SCAN_CLEAN_EXIT_CODES=0
COLLECTION_RECEIPT_EXTERNAL_SCAN_REJECT_EXIT_CODES=1

# Mail / activation / password reset
# Leave all SMTP_* values empty if email delivery is disabled.
# Set real SMTP credentials only in private environment files or secret stores. Never commit them.
MAIL_FROM=
SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
MAIL_DEV_OUTBOX_ENABLED=0
MAIL_DEV_OUTBOX_DIR=var/dev-mail-outbox
MAIL_DEV_OUTBOX_MAX_FILES=100

# AI / Ollama
# Required when AI chat or semantic embedding features are enabled. If you do
# not run Ollama, leave these values at safe defaults and expect AI requests to
# fail closed or use the app's non-AI fallbacks instead.
# Embedding-backed search also requires PostgreSQL pgvector support. Ensure the
# database can run:
#   CREATE EXTENSION IF NOT EXISTS vector;
# The reviewed migrations attempt this automatically, but managed PostgreSQL
# hosts may require the extension package to be enabled separately first.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=6000
DEFAULT_AI_TIMEOUT_MS=6000
AI_DEBUG=0
AI_PRECOMPUTE_ON_START=0
AI_GATE_GLOBAL_LIMIT=4
AI_GATE_SUPERUSER_LIMIT=1
AI_GATE_ADMIN_LIMIT=1
AI_GATE_USER_LIMIT=2
AI_GATE_QUEUE_LIMIT=20
AI_GATE_QUEUE_WAIT_MS=12000
AI_LATENCY_DECAY_HALF_LIFE_MS=30000
AI_LATENCY_STALE_AFTER_MS=20000

# Search / runtime tuning
SQR_LOW_MEMORY_MODE=1
SQR_MAX_SEARCH_CACHE_ENTRIES=60
SQR_MAX_AI_LAST_PERSON_ENTRIES=40
SQR_AI_LAST_PERSON_TTL_MS=1800000
# When SQR_MAX_WORKERS=1, the server now starts in single-process mode to avoid an unnecessary cluster master.
# Set SQR_INITIAL_WORKERS to control how many workers boot immediately. It cannot exceed SQR_MAX_WORKERS.
# Set SQR_FORCE_CLUSTER=1 only if you explicitly need cluster IPC behavior while keeping one worker.
SQR_MAX_WORKERS=1
SQR_INITIAL_WORKERS=1
SQR_FORCE_CLUSTER=0
SQR_PREALLOCATE_MB=0

# Request limits / analytics
IMPORT_BODY_LIMIT=96mb
# Caps the total staged multipart import bytes a single authenticated user can
# upload at one time. Keep this at or above IMPORT_BODY_LIMIT so one normal
# upload can still complete, and raise it only if you intentionally allow
# multiple concurrent imports per user.
IMPORT_PER_USER_ACTIVE_UPLOAD_BYTES=100663296
# Backward-compatible row cap used for CSV uploads and as a server-side safety
# guard for spreadsheet imports before rows are materialized into import records.
IMPORT_CSV_MAX_ROWS=100000
COLLECTION_BODY_LIMIT=8mb
DEFAULT_BODY_LIMIT=2mb
HTTP_SLOW_REQUEST_MS=1500
HTTP_REQUEST_TIMEOUT_MS=30000
# Raise this queue threshold if your production pool is intentionally bursty.
PG_POOL_ALERT_WAITING_COUNT=2
# Pool saturation threshold used before pressure warnings are emitted.
PG_POOL_ALERT_UTILIZATION_PERCENT=100
PG_POOL_HEALTH_CHECK_INTERVAL_MS=60000
PG_POOL_HEALTH_CHECK_TIMEOUT_MS=5000
# Optional staging/load-test helper for per-request DB query profiling.
# Leave disabled in normal production traffic. When enabled, the app will log
# high-query or repeated-statement request patterns so you can validate N+1
# risks under smoke/load runs without changing app behavior for ordinary users.
DB_QUERY_PROFILING_ENABLED=0
# Production now forces this profiler off unless you also set the explicit
# temporary override below for a short, controlled troubleshooting window.
DB_QUERY_PROFILING_ALLOW_IN_PRODUCTION=0
# Sample percentage for profiled requests when DB_QUERY_PROFILING_ENABLED=1.
DB_QUERY_PROFILING_SAMPLE_PERCENT=100
# Log when a request reaches at least this many SQL statements.
DB_QUERY_PROFILING_MIN_QUERY_COUNT=8
# Log when cumulative DB time for one request reaches this threshold.
DB_QUERY_PROFILING_MIN_TOTAL_QUERY_MS=40
# Flag a repeated statement as suspicious when the same normalized SQL shape
# executes this many times within one request.
DB_QUERY_PROFILING_REPEATED_STATEMENT_THRESHOLD=3
# Limit how many repeated statement groups are included in one warning log.
DB_QUERY_PROFILING_MAX_LOGGED_STATEMENTS=5
# Limit how many distinct normalized SQL shapes are tracked for one profiled request.
DB_QUERY_PROFILING_MAX_UNIQUE_STATEMENTS=250
# Optional lightweight client runtime error forwarding to the internal telemetry route.
# Enable together with VITE_CLIENT_ERROR_TELEMETRY so browser-side boundaries and global handlers
# can report sanitized failures back to the server logger.
CLIENT_ERROR_TELEMETRY_ENABLED=0
ANALYTICS_TZ=Asia/Kuala_Lumpur
DEFAULT_SESSION_TIMEOUT_MINUTES=30
DEFAULT_WS_IDLE_MINUTES=3
DEFAULT_SEARCH_RESULT_LIMIT=200
DEFAULT_VIEWER_ROWS_PER_PAGE=100
MAINTENANCE_CACHE_TTL_MS=3000
RUNTIME_SETTINGS_CACHE_TTL_MS=3000
PG_POOL_WARN_COOLDOWN_MS=60000
GRACEFUL_SHUTDOWN_TIMEOUT_MS=25000
# Backup routes keep their own longer request timeout so export and restore
# streams do not inherit the shorter global HTTP deadline.
BACKUP_OPERATION_TIMEOUT_MS=120000
IMPORT_ANALYSIS_TIMEOUT_MS=45000
BACKUP_RESTORE_MAX_TRACKED_COLLECTION_RECORD_IDS=250000
COLLECTION_ROLLUP_LISTEN_RECONNECT_MS=5000

# Backup safety
BACKUP_FEATURE_ENABLED=1
# Required outside strict local development when backups are enabled.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Store outside the backup destination. Losing this key means encrypted backups cannot be restored.
BACKUP_ENCRYPTION_KEY=GENERATE_ME_BACKUP_KEY_AND_STORE_OFFLINE
BACKUP_ENCRYPTION_KEYS=
BACKUP_ENCRYPTION_KEY_ID=
# Refuse backup create/export payloads that exceed this byte limit to avoid runaway memory pressure.
# Increase only after verifying production memory headroom and backup export timings.
BACKUP_MAX_PAYLOAD_BYTES=33554432

# Local-only helpers
# DANGER: local troubleshooting only. Never enable this on public, staging, or
# production hosts. When enabled, local superuser credentials may be read from
# or written to a filesystem helper file, so leaked server files could expose
# emergency credentials.
LOCAL_SUPERUSER_CREDENTIALS_FILE_ENABLED=0

# Optional seed data for local development only
SEED_DEFAULT_USERS=0
SEED_SUPERUSER_USERNAME=
SEED_SUPERUSER_PASSWORD=
SEED_SUPERUSER_FULL_NAME=
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FULL_NAME=
SEED_USER_USERNAME=
SEED_USER_PASSWORD=
SEED_USER_FULL_NAME=

# Frontend telemetry build flags
VITE_CLIENT_ERROR_TELEMETRY=0
