{
  "name": "sqr-local",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "verify:node-version": "node scripts/verify-node-version.mjs",
    "verify:repo-hygiene": "node scripts/verify-repo-hygiene.mjs",
    "verify:db-schema-governance": "node scripts/verify-db-schema-governance.mjs",
    "verify:bundle-budgets": "node scripts/verify-client-bundle-budgets.mjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:generate:custom": "drizzle-kit generate --config drizzle.config.ts --custom",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:cli": "drizzle-kit migrate --config drizzle.config.ts",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:introspect": "drizzle-kit introspect --config drizzle.config.ts",
    "test:client": "node scripts/run-client-tests.mjs",
    "test:scripts": "node --test scripts/tests/*.test.mjs",
    "test:db-integration": "tsx --test server/http/tests/bootstrap-migration.integration.test.ts",
    "test:http": "tsx --test server/http/tests/*.test.ts",
    "test:services": "tsx --test server/services/tests/*.test.ts",
    "test:repositories": "tsx --test server/repositories/tests/*.test.ts",
    "test:routes": "tsx --test server/routes/tests/*.test.ts",
    "test:ws": "tsx --test server/ws/tests/*.test.ts",
    "test:intelligence": "tsx --test server/intelligence/tests/*.test.ts",
    "test": "npm run test:client && npm run test:scripts && npm run test:http && npm run test:services && npm run test:repositories && npm run test:routes && npm run test:ws && npm run test:intelligence",
    "perf:collection:baseline": "node scripts/perf-collection-baseline.mjs",
    "dr:drill": "node scripts/disaster-recovery-drill.mjs",
    "smoke:preflight": "node scripts/smoke-preflight.mjs",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "smoke:ci-local": "node scripts/smoke-ci-local.mjs",
    "release:verify:local": "node scripts/release-readiness-local.mjs",
    "monitor:stale-conflicts": "node scripts/monitor-stale-conflicts.mjs",
    "dev": "npm run dev:server",
    "dev:server": "tsx server/index-local.ts",
    "build": "npx vite build && npx esbuild server/index-local.ts --bundle --platform=node --packages=external --outfile=dist-local/server/index-local.js --format=esm && npx esbuild server/cluster-local.ts --bundle --platform=node --packages=external --outfile=dist-local/server/cluster-local.js --format=esm",
    "start": "npm run start:built",
    "prestart": "node scripts/ensure-build.mjs",
    "start:built": "node dist-local/server/cluster-local.js",
    "import:aeon-branches": "node scripts/import-aeon-branches.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.60.5",
    "bcrypt": "^6.0.0",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "framer-motion": "^11.13.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.453.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.7",
    "react-window": "^1.8.11",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.2.5",
    "vaul": "^1.1.2",
    "wouter": "^3.3.5",
    "ws": "^8.18.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/bcrypt": "^6.0.0",
    "@types/busboy": "^1.5.4",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "24.12.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "5.6.3",
    "vite": "^6.4.1"
  },
  "overrides": {
    "qs": "^6.15.0",
    "lodash": "^4.17.23",
    "rollup": "^4.59.0",
    "dompurify": "^3.3.3"
  }
}
