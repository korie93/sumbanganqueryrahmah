module.exports = {
  apps: [
    {
      name: "sqr",
      cwd: "/absolute/path/to/sumbanganqueryrahmah",
      script: "npm",
      args: "start",
      interpreter: "none",
      instances: 1,
      // Keep one PM2 app instance here because `npm start` launches the repo's
      // own clustered runtime entrypoint. Scale worker count through
      // SQR_MAX_WORKERS / SQR_INITIAL_WORKERS instead of layering PM2 cluster
      // mode on top of the app's internal cluster manager.
      // This example keeps the npm wrapper for parity with `npm start`.
      // PM2 `wait_ready` is intentionally not enabled here because readiness
      // handshakes require a direct Node entrypoint that emits `process.send("ready")`.
      // If you switch `script` to the built Node file directly, you can enable
      // `wait_ready` and keep the listen/kill windows below.
      // The app loads secrets from .env in the working directory via dotenv/config.
      // Keep real secrets in .env, not in this file.
      env: {
        NODE_ENV: "production",
        HOST: "0.0.0.0",
        PORT: "5000",
      },
      max_memory_restart: "768M",
      min_uptime: "15s",
      max_restarts: 10,
      exp_backoff_restart_delay: 100,
      restart_delay: 5000,
      kill_timeout: 30000,
      listen_timeout: 10000,
      time: true,
    },
  ],
};
