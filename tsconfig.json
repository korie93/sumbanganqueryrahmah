{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    // Keep skipLibCheck enabled after the 2026-04-19 reassessment.
    // `tsc --noEmit --skipLibCheck false` still fails in third-party
    // declarations (not app code), including Drizzle cross-driver packages
    // and Redux Toolkit vendor typings. The previous local CSS module
    // duplicate was removed, so the remaining blockers are upstream typings.
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["client/src", "server", "shared"]
}
